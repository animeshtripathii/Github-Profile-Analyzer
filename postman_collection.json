{
  "info": {
    "_postman_id": "github-profile-analyzer-collection",
    "name": "GitHub Profile Analyzer",
    "description": "API collection for the GitHub Profile Analyzer service.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      },
      "response": []
    },
    {
      "name": "Analyze Profile",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "none"
        },
        "url": {
          "raw": "{{base_url}}/api/profiles/analyze/torvalds",
          "host": ["{{base_url}}"],
          "path": ["api", "profiles", "analyze", "torvalds"]
        }
      },
      "response": []
    },
    {
      "name": "Refresh Profile",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "none"
        },
        "url": {
          "raw": "{{base_url}}/api/profiles/analyze/torvalds/refresh",
          "host": ["{{base_url}}"],
          "path": ["api", "profiles", "analyze", "torvalds", "refresh"]
        }
      },
      "response": []
    },
    {
      "name": "List All Profiles",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/profiles?page=1&limit=20&sort=total_stars&order=desc",
          "host": ["{{base_url}}"],
          "path": ["api", "profiles"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "20" },
            { "key": "sort", "value": "total_stars" },
            { "key": "order", "value": "desc" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Single Profile",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/profiles/torvalds",
          "host": ["{{base_url}}"],
          "path": ["api", "profiles", "torvalds"]
        }
      },
      "response": []
    },
    {
      "name": "Delete Profile",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/profiles/torvalds",
          "host": ["{{base_url}}"],
          "path": ["api", "profiles", "torvalds"]
        }
      },
      "response": []
    }
  ]
}
